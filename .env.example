# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Vercel Postgres (Database)
# These are automatically provided by Vercel when you connect a Postgres store
POSTGRES_URL="postgres://default:password@ep-host.region.aws.neon.tech:5432/verceldb"

# Vercel Blob (Images)
# Provided by Vercel when you connect a Blob store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
